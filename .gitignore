# =============================================================================
# R session artifacts
# =============================================================================
.Rhistory
.RData
.Ruserdata

# =============================================================================
# RStudio project files and state
# =============================================================================
*.Rproj
.Rproj.user/

# =============================================================================
# R CMD check output
# =============================================================================
.Rcheck/
*.Rcheck/

# =============================================================================
# Built package bundles
# =============================================================================
*.tar.gz
*.zip

# =============================================================================
# Auto-generated directories created during build and documentation
# These are regenerated by devtools::document(), R CMD build, or pkgdown.
# =============================================================================
/doc/
/Meta/
/inst/doc/

# =============================================================================
# pkgdown site output
# =============================================================================
/docs/

# =============================================================================
# Vignette build artifacts
# Created by knitr/rmarkdown during devtools::build_vignettes().
# =============================================================================
vignettes/*.html
vignettes/*.R

# =============================================================================
# Compiled code artifacts
# OptiSparseMET is pure R, but these entries ensure compiled objects are
# ignored if C or C++ code is added in the future.
# =============================================================================
*.o
*.so
*.dll
src/*.o
src/*.so
src/*.dll

# =============================================================================
# Log files produced by LaTeX and knitr
# =============================================================================
*.log

# =============================================================================
# CRAN submission notes
# =============================================================================
cran-comments.md

# =============================================================================
# OS-generated metadata files
# =============================================================================
.DS_Store
Thumbs.db
