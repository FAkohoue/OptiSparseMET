\details{
\subsection{Mixed model}{

The model is:
\deqn{y = X\beta + Zu + e}

\strong{Fixed part} \eqn{X}: intercept, optional check fixed effects
(\code{check_as_fixed = TRUE}), entry treatment fixed effects when
\code{treatment_effect = "fixed"}.

\strong{Random part} \eqn{Z}: replicate, incomplete block within replicate, row,
column, and - when \code{treatment_effect = "random"} - entry treatment effects.

\strong{Residual structure} \eqn{R = \sigma_e^2 \Sigma}:
\itemize{
\item \code{"IID"}: \eqn{\Sigma = I}
\item \code{"AR1"}: row-only AR1,
\eqn{Q_\text{AR1}(\rho_\text{row}) \otimes I_\text{cols}}
\item \code{"AR1xAR1"}: separable row x column AR1,
\eqn{Q_\text{AR1}(\rho_\text{col}) \otimes Q_\text{AR1}(\rho_\text{row})}
}

AR1 precision matrices are tridiagonal sparse matrices. For an
\eqn{n}-dimensional AR1 process with parameter \eqn{\rho}, let
\eqn{a = 1/(1-\rho^2)}:
\itemize{
\item Interior diagonal: \eqn{(1+\rho^2) \times a}
\item Edge diagonal (positions 1 and \eqn{n}): \eqn{a}
\item Off-diagonal: \eqn{-\rho \times a}
}
}

\subsection{Mixed model coefficient matrix}{

\deqn{C = \begin{pmatrix} X^\top Q X & X^\top Q Z \\ Z^\top Q X &
  Z^\top Q Z + G^{-1} \end{pmatrix}}

where \eqn{Q = R^{-1}} is the residual precision matrix.
}

\subsection{Random-effect structure G}{
\itemize{
\item \code{"IID"}: \eqn{G^{-1}_\text{entry} = \sigma_g^{-2} I}
\item \code{"GBLUP"} / \code{"PBLUP"}: \eqn{G^{-1}_\text{entry} = \sigma_g^{-2} K^{-1}},
computed via sparse Cholesky; falls back to Moore-Penrose pseudoinverse
for near-singular \code{K}.
}
}

\subsection{Optimality criteria}{
\subsection{Fixed treatment effects}{

\strong{A-criterion} (lower = better):
\deqn{A_\text{criterion} = \bar{v}_\text{diff} =
  \frac{2}{p(p-1)} \sum_{i<j} \text{Var}(\hat{\tau}_i - \hat{\tau}_j)}

\strong{D-criterion} (lower = better):
\deqn{D_\text{criterion} = \exp\!\left(\frac{\log\det(HVH)}{p-1}\right)}
where \eqn{H = I_p - p^{-1}J_p} is the centering matrix and \eqn{V} is
the treatment variance-covariance submatrix.

\strong{Efficiency forms} (higher = better):
\deqn{A_\text{efficiency} = 1 / A_\text{criterion}, \quad
      D_\text{efficiency} = 1 / D_\text{criterion}}
}

\subsection{Random treatment effects (genomic prediction)}{

\strong{PEV-criterion} (lower = better): mean prediction error variance across
all entry lines.
\deqn{\text{PEV}_\text{criterion} = \frac{1}{p}\sum_{i=1}^{p}
  \text{Var}(\hat{u}_i - u_i)}

\strong{CDmean} (higher = better): mean coefficient of determination for genomic
breeding value prediction (Rincent et al. 2012, \emph{Genetics} 192:715-728).
\deqn{\text{CDmean} = 1 - \frac{\text{PEV}_\text{criterion}}{\sigma_g^2}}

CDmean measures the proportion of genetic variance explained by GEBV
predictions on average across lines. Values close to 1 indicate highly
reliable predictions; values close to 0 indicate near-uninformative
predictions. CDmean is only defined when \code{treatment_effect = "random"}.

\strong{CD per line}: when the number of treatments does not exceed
\code{eff_full_max}, a per-line coefficient of determination vector is also
returned:
\deqn{CD_i = 1 - \text{PEV}_i / \sigma_g^2}
}

}

\subsection{Large-design approximation}{

When the number of treatments exceeds \code{eff_full_max}, a Hutchinson
stochastic trace estimator with \code{eff_trace_samples} Rademacher vectors
replaces exact submatrix extraction. The \code{mode} field carries the suffix
\verb{_APPROX} and \code{D_criterion}, \code{D_efficiency}, and \code{CD_per_line} are \code{NA}.
}
}
