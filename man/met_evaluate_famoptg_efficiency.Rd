\description{
\code{met_evaluate_famoptg_efficiency()} is the OptiSparseMET version of
\code{evaluate_famoptg_efficiency()} from the OptiDesign package. The \code{met_}
prefix avoids namespace conflicts when both packages are loaded
simultaneously. All arguments, return values, and internal logic are
identical to \code{evaluate_famoptg_efficiency()} in OptiDesign.

\code{met_evaluate_famoptg_efficiency()} takes a \code{field_book} produced by
\code{\link[=met_prep_famoptg]{met_prep_famoptg()}} and computes optimality criteria under a
user-specified mixed model. It is fully decoupled from design construction
so that a single design can be evaluated multiple times under different
model assumptions without rebuilding the layout.

This function is the sibling of \code{met_evaluate_alpha_efficiency()} for
\code{\link[=met_alpha_rc_stream]{met_alpha_rc_stream()}} designs. The key structural difference is that
\code{\link[=met_prep_famoptg]{met_prep_famoptg()}} designs have a single flat blocking structure (one set
of \code{n_blocks} blocks with no replicate or incomplete-block nesting), so
the random effect model here contains \strong{Block + Row + Column} rather than
the \strong{Rep + IBlock(Rep) + Row + Column} structure of alpha-lattice designs.
}
\details{
\subsection{Mixed model}{

\deqn{y = X\beta + Zu + e}

\strong{Fixed part} \eqn{X}: intercept, optional check fixed effects
(\code{check_as_fixed = TRUE}), entry fixed effects when
\code{treatment_effect = "fixed"}.

\strong{Random part} \eqn{Z}: block, row, column, and - when
\code{treatment_effect = "random"} - entry treatment effects. There is no
replicate or incomplete-block term because \code{\link[=met_prep_famoptg]{met_prep_famoptg()}} has no
such nesting.

\strong{Residual structure} \eqn{R = \sigma_e^2 \Sigma}:
\itemize{
\item \code{"IID"}: \eqn{\Sigma = I}
\item \code{"AR1"}: row-only AR1,
\eqn{Q_\text{AR1}(\rho_\text{row}) \otimes I_\text{cols}}
\item \code{"AR1xAR1"}: separable row x column AR1,
\eqn{Q_\text{AR1}(\rho_\text{col}) \otimes Q_\text{AR1}(\rho_\text{row})}
}
}

\subsection{Mixed model coefficient matrix}{

\deqn{C = \begin{pmatrix} X^\top Q X & X^\top Q Z \\ Z^\top Q X &
  Z^\top Q Z + G^{-1} \end{pmatrix}}

where \eqn{Q = R^{-1}} and \eqn{G^{-1}} is block-diagonal with:
\itemize{
\item Block random effects: \eqn{\sigma_b^{-2} I}
\item Row random effects: \eqn{\sigma_r^{-2} I}
\item Column random effects: \eqn{\sigma_c^{-2} I}
\item Entry random effects (when \code{treatment_effect = "random"}):
\eqn{\sigma_g^{-2} I} (IID) or \eqn{\sigma_g^{-2} K^{-1}} (GBLUP/PBLUP)
}
}

\subsection{Optimality criteria}{
\subsection{Fixed treatment effects}{

\strong{A-criterion} (lower = better):
\deqn{A_\text{criterion} = \bar{v}_\text{diff} =
  \frac{2}{p(p-1)} \sum_{i<j} \text{Var}(\hat{\tau}_i - \hat{\tau}_j)}

\strong{D-criterion} (lower = better):
\deqn{D_\text{criterion} =
  \exp\!\left(\frac{\log\det(HVH)}{p-1}\right)}
where \eqn{H = I_p - p^{-1}J_p} and \eqn{V} is the treatment
variance-covariance submatrix of \eqn{C^{-1}}.

\strong{Efficiency forms} (higher = better):
\deqn{A_\text{efficiency} = 1 / A_\text{criterion}, \quad
      D_\text{efficiency} = 1 / D_\text{criterion}}
}

\subsection{Random treatment effects (genomic prediction)}{

\strong{PEV-criterion} (lower = better): mean prediction error variance.
\deqn{\text{PEV}_\text{criterion} = \frac{1}{p}
  \sum_{i=1}^{p} \text{Var}(\hat{u}_i - u_i)}

\strong{CDmean} (higher = better): mean coefficient of determination for
GEBV prediction (Rincent et al. 2012, \emph{Genetics} 192:715-728):
\deqn{\text{CDmean} = 1 - \frac{\text{PEV}_\text{criterion}}{\sigma_g^2}}

\strong{CD per line}: per-line coefficient of determination:
\deqn{CD_i = 1 - \text{PEV}_i / \sigma_g^2}
Available in full mode only; \code{NA} in \verb{_APPROX} mode.
}

}

\subsection{Large-design approximation}{

When the number of treatments exceeds \code{eff_full_max}, a Hutchinson
stochastic trace estimator with \code{eff_trace_samples} Rademacher vectors
replaces exact submatrix extraction. The \code{mode} field carries the suffix
\verb{_APPROX} and \code{D_criterion}, \code{D_efficiency}, and \code{CD_per_line} are \code{NA}.
}
}
\examples{
design <- met_prep_famoptg(
  check_treatments        = c("CHK1", "CHK2"),
  check_families          = c("CHECK", "CHECK"),
  p_rep_treatments        = paste0("P", 1:20),
  p_rep_reps              = rep(2L, 20),
  p_rep_families          = rep(paste0("F", 1:4), 5),
  unreplicated_treatments = paste0("U", 1:60),
  unreplicated_families   = rep(paste0("F", 1:4), 15),
  n_blocks = 5, n_rows = 15, n_cols = 20
)

## Fixed-effect evaluation (BLUE contrasts, IID residuals)
eff_fixed <- met_evaluate_famoptg_efficiency(
  field_book       = design$field_book,
  n_rows = 15, n_cols = 20,
  check_treatments = c("CHK1", "CHK2"),
  treatment_effect = "fixed"
)
eff_fixed$A_criterion   # lower is better
eff_fixed$D_criterion   # lower is better
eff_fixed$A_efficiency  # higher is better

## AR1xAR1 spatial model
eff_spatial <- met_evaluate_famoptg_efficiency(
  field_book         = design$field_book,
  n_rows = 15, n_cols = 20,
  check_treatments   = c("CHK1", "CHK2"),
  treatment_effect   = "fixed",
  residual_structure = "AR1xAR1",
  rho_row = 0.10, rho_col = 0.10
)
eff_spatial$A_criterion

